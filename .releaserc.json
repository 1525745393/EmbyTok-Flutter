{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "cd frontend && flutter pub get && flutter analyze --no-pub lib | (grep '^   error' && exit 1 || true)",
        "prepareCmd": "BUILD_NUM=$(echo ${nextRelease.version} | tr -d '.' | sed 's/^0*//') && sed -i \"s/^version: .*/version: ${nextRelease.version}+$BUILD_NUM/\" frontend/pubspec.yaml && cat frontend/pubspec.yaml | grep '^version:'",
        "publishCmd": "chmod +x scripts/android-ci-release.sh && scripts/android-ci-release.sh"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["frontend/pubspec.yaml", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "frontend/build/app/outputs/flutter-apk/app-arm64-v8a-release.apk",
            "label": "APK (arm64-v8a) - ${nextRelease.version}"
          },
          {
            "path": "frontend/build/app/outputs/flutter-apk/app-armeabi-v7a-release.apk",
            "label": "APK (armeabi-v7a) - ${nextRelease.version}"
          },
          {
            "path": "frontend/build/app/outputs/flutter-apk/app-x86_64-release.apk",
            "label": "APK (x86_64) - ${nextRelease.version}"
          },
          {
            "path": "frontend/build/app/outputs/flutter-apk/app-release.apk",
            "label": "APK (universal) - ${nextRelease.version}"
          },
          {
            "path": "frontend/build/app/outputs/bundle/release/app-release.aab",
            "label": "AAB (Android App Bundle) - ${nextRelease.version}"
          }
        ]
      }
    ]
  ]
}